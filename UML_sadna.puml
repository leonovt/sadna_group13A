}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.Company
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Company" #FFF9C4 {

    enum CompanyRole {
        FOUNDER
        OWNER
        MANAGER
    }

    enum CompanyPermission {
        MANAGE_EVENTS
        MANAGE_POLICIES
        MANAGE_DISCOUNTS
        VIEW_REPORTS
    }

    enum CompanyStatus {
        ACTIVE
        INACTIVE
    }

    class ProductionCompany <<AggRoot>> #FFD54F {
        - id          : String
        - name        : String
        - description : String
        - status      : CompanyStatus
        - version     : long
        + nominateStaff(actingUserId, nomineeId, role, permissions)
        + acceptNomination(nomineeId)
        + rejectNomination(nomineeId)
        + fireStaff(actingUserId, targetUserId)
        + forceRemoveStaff(userId)
        + resign(actingUserId)
        + updatePermissions(actingUserId, targetManagerId, newPerms)
        + suspendCompany(actingUserId)
        + reopenCompany(actingUserId)
        + forceClose()
        + isFounder(userId) : boolean
        + isOwner(userId)   : boolean
        + isManager(userId) : boolean
        + hasPermission(userId, perm) : boolean
        + getStaffSubTree(rootUserId) : Set<String>
        + getRoleTree(actingUserId)   : Map<String, CompanyStaffMember>
        + setPurchasePolicy(policy)
        + setDiscountPolicy(policy)
    }

    class CompanyStaffMember {
        - userId           : String
        - role             : CompanyRole
        - appointedByUserId: String
        - permissions      : Set<CompanyPermission>
        + setPermissions(perms)
        + setAppointedByUserId(id)
    }

    class AppointmentRequest {
        - nomineeId          : String
        - appointerId        : String
        - proposedRole       : CompanyRole
        - proposedPermissions: Set<CompanyPermission>
    }

    ProductionCompany "1" *-- "0..*" CompanyStaffMember  : staff
    ProductionCompany "1" *-- "0..*" AppointmentRequest  : pendingAppointments
    ProductionCompany  --> CompanyStatus
    CompanyStaffMember --> CompanyRole
    CompanyStaffMember --> CompanyPermission
    AppointmentRequest --> CompanyRole
    AppointmentRequest --> CompanyPermission
    ProductionCompany ..> PurchasePolicy
    ProductionCompany ..> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.Event
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Event" #FFF9C4 {

    enum EventSaleMode {
        REGULAR
        QUEUE
        RAFFLE
    }

    enum SeatStatus {
        AVAILABLE
        HELD
        SOLD
    }

    enum ZoneType {
        STANDING
        SEATED
    }

    class Event <<AggRoot>> #FFD54F {
        - id          : String
        - title       : String
        - description : String
        - companyId   : String
        - eventDate   : LocalDateTime
        - category    : String
        - location    : String
        - published   : boolean
        - saleMode    : EventSaleMode
        - version     : long
        + publish()
        + unpublish()
        + setVenueMap(map)
        + reserveSeat(zoneId, seatId, userId)
        + sellItem(zoneId, seatId, userId) : String
        + unsellItem(zoneId, seatId)
        + releaseItem(zoneId, seatId, userId)
        + getZoneById(zoneId) : Zone
        + getZoneBasePrice(zoneId) : double
        + getTotalAvailable() : int
        + setPurchasePolicy(policy)
        + setDiscountPolicy(policy)
    }

    class VenueMap {
        - id        : String
        - venueName : String
        + addZone(zone)
        + getZoneById(zoneId) : Zone
        + getTotalCapacity() : int
        + getTotalAvailable() : int
    }

    abstract class Zone {
        - id        : String
        - name      : String
        - basePrice : double
        - type      : ZoneType
        + getAvailableSeatCount() : int
        + getMaxCapacity() : int
    }

    class SeatedZone {
        + findSeatById(seatId) : Optional<Seat>
    }

    class StandingZone {
        - maxCapacity : int
        - heldCount   : int
        - soldCount   : int
        + holdStandingSpot(userId)
        + sellStandingSpot(userId)
        + releaseStandingSpot(userId)
        + unsellStandingSpot()
    }

    class Seat {
        - id            : String
        - label         : String
        - status        : SeatStatus
        - heldByUserId  : String
        - holdExpiresAt : Instant
        + hold(userId)
        + hold(userId, duration)
        + release()
        + sell(userId)
        + unsell()
        + getEffectiveStatus() : SeatStatus
    }

    Event      "1" *-- "0..1" VenueMap   : venueMap
    VenueMap   "1" *-- "1..*" Zone       : zones
    Zone       <|-- SeatedZone
    Zone       <|-- StandingZone
    SeatedZone "1" *-- "1..*" Seat       : seats
    Event       --> EventSaleMode
    Zone        --> ZoneType
    Seat        --> SeatStatus
    Event       ..> PurchasePolicy
    Event       ..> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.ActiveOrder  (shopping cart, 30-min expiry)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.ActiveOrder" #FFF9C4 {

    class ActiveOrder <<AggRoot>> #FFD54F {
        - id        : String
        - userId    : String
        - status    : OrderStatus
        - createdAt : LocalDateTime
        - expiresAt : LocalDateTime
        - version   : long
        ' Timer starts at construction (+30 min)
        + addItem(item)
        + removeItem(item)
        + removeItemByKey(eventId, zoneId, seatId) : boolean
        + submit()
        + cancel()
        + isExpired() : boolean
        + getTotalPrice() : double
    }

    class OrderItem <<VO>> {
        - eventId   : String
        - zoneId    : String
        - seatId    : String
        - basePrice : double
    }

    ActiveOrder "1" *-- "0..*" OrderItem : items
    ActiveOrder --> OrderStatus
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.OrderHistory  (receipts + checkout session)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.OrderHistory" #FFF9C4 {

    class OrderHistory <<AggRoot>> #FFD54F {
        - receiptId    : String
        - userId       : String
        - purchaseDate : LocalDateTime
        - totalPaid    : double
        + containsItemFromCompany(companyId) : boolean
    }

    class OrderHistoryItem <<VO>> {
        - eventId     : String
        - eventTitle  : String
        - eventDate   : LocalDateTime
        - companyId   : String
        - companyName : String
        - zoneName    : String
        - seatLabel   : String
        - pricePaid   : double
    }

    class ActiveOrder <<AggRoot>> #FFD54F {
        ' Checkout session (10-min expiry, timer starts on first item)
        {static} EXPIRATION_MINUTES = 10
        - orderId       : String
        - userId        : String
        - userRole      : UserRole
        - status        : OrderStatus
        - createdAt     : LocalDateTime
        - expiresAt     : LocalDateTime
        - transactionId : String
        + addItem(item)
        + removeItem(item)
        + calculateTotalBasePrice() : double
        + complete(transactionId)
        + cancel()
        + isExpired() : boolean
    }

    class OrderItem <<VO>> {
        - eventId   : String
        - zoneId    : String
        - seatId    : String
        - basePrice : double
    }

    OrderHistory "1" *-- "1..*" OrderHistoryItem : items
    ActiveOrder  "1" *-- "0..*" OrderItem        : items
    ActiveOrder  --> OrderStatus
    ActiveOrder  --> UserRole
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.Raffle
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Raffle" #FFF9C4 {

    enum RaffleStatus {
        OPEN_FOR_REGISTRATION
        DRAWN
        CLOSED
    }

    class Raffle <<AggRoot>> #FFD54F {
        - id        : String
        - eventId   : String
        - companyId : String
        - status    : RaffleStatus
        - version   : long
        + registerParticipant(userId)
        + executeDraw(numberOfWinners, codeValidMinutes)
        + getAuthorizationCodeFor(userId) : Optional<AuthorizationCode>
        + close()
        + getParticipantUserIds() : Set<String>
        + getWinningCodes() : Collection<AuthorizationCode>
    }

    class AuthorizationCode {
        - code           : String
        - userId         : String
        - eventId        : String
        - expirationTime : LocalDateTime
        + isValidFor(userId, eventId) : boolean
    }

    Raffle "1" *-- "0..*" AuthorizationCode : winners
    Raffle --> RaffleStatus
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.TicketQueue
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.TicketQueue" #FFF9C4 {

    class TicketQueue <<AggRoot>> #FFD54F {
        - eventId            : String
        - maxConcurrentUsers : int
        - version            : long
        + joinQueue(userId)
        + processBatch(batchSize, validMinutes) : List<QueueTicket>
        + removeActiveUser(userId)
        + removeWaitingUser(userId) : boolean
        + clearQueue()
        + adjustMaxConcurrentUsers(newMax)
        + isUserActive(userId) : boolean
        + getActiveTicket(userId) : Optional<QueueTicket>
        + getWaitingTicket(userId) : Optional<QueueTicket>
        + getWaitingCount() : int
        + getActiveCount()  : int
        + getActiveUserIds() : Set<String>
    }

    class QueueTicket {
        - userId         : String
        - positionInLine : int
        - grantedAt      : LocalDateTime
        - expiresAt      : LocalDateTime
        + grantAccess(validMinutes)
        + decrementPosition(amount)
        + hasAccess() : boolean
    }

    TicketQueue "1" *-- "0..*" QueueTicket : activeUsers / waitingUsers
}

