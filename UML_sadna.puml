'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Shared
'══════════════════════════════════════════════════════════════════

package "domain.shared" #FFFDE7 {

    interface PurchasePolicy
    interface DiscountPolicy

    enum    OrderStatus
    class   PurchaseContext <<record>>
    class   DiscountContext <<record>>

    class DomainException
    class AuthenticationException
    class EntityNotFoundException
    class PermissionDeniedException
    class SeatUnavailableException
    class OptimisticLockException

    DomainException <|-- AuthenticationException
    DomainException <|-- EntityNotFoundException
    DomainException <|-- PermissionDeniedException
    DomainException <|-- SeatUnavailableException
    RuntimeException <|-- OptimisticLockException
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Policies
'══════════════════════════════════════════════════════════════════

package "domain.policies.purchase" #FFFDE7 {
    class AllowAllPolicy
    class AndPolicy
    class OrPolicy
    class MaxTicketsPolicy
    class MinTicketsPolicy
    class AgeRestrictionPolicy

    AllowAllPolicy       ..|> PurchasePolicy
    AndPolicy            ..|> PurchasePolicy
    OrPolicy             ..|> PurchasePolicy
    MaxTicketsPolicy     ..|> PurchasePolicy
    MinTicketsPolicy     ..|> PurchasePolicy
    AgeRestrictionPolicy ..|> PurchasePolicy
}

package "domain.policies.discount" #FFFDE7 {
    class NoDiscountPolicy
    class SimpleDiscount
    class AdditiveDiscountPolicy
    class MaxDiscountPolicy
    class ConditionalDiscount
    class CouponDiscount

    NoDiscountPolicy       ..|> DiscountPolicy
    SimpleDiscount         ..|> DiscountPolicy
    AdditiveDiscountPolicy ..|> DiscountPolicy
    MaxDiscountPolicy      ..|> DiscountPolicy
    ConditionalDiscount    ..|> DiscountPolicy
    CouponDiscount         ..|> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — User  (State pattern)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.User" #FFF9C4 {
    class  User   <<AggRoot>>
    class  Member
    class  Guest
    enum   UserRole
    enum   UserState
    enum   UserType

    interface UserTypeState
    class     MemberState
    class     GuestState
    class     AdminState

    User   <|-- Member
    User   <|-- Guest
    User   --> UserState
    User   --> UserRole
    User   --> UserType
    User   --> UserTypeState

    MemberState ..|> UserTypeState
    GuestState  ..|> UserTypeState
    AdminState  ..|> UserTypeState
}

