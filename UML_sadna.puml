@startuml UML_sadna_group13A
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho

title Sadna Group 13A — Event Ticketing System (Detailed Class Diagram)

'══════════════════════════════════════════════════════════════════
' DOMAIN — shared
'══════════════════════════════════════════════════════════════════

package "domain.shared" #FFFDE7 {

    enum OrderStatus {
        OPEN
        PENDING_PAYMENT
        COMPLETED
        CANCELLED
    }

    interface PurchasePolicy {
        + isSatisfied(ctx : PurchaseContext) : boolean
    }

    interface DiscountPolicy {
        + calculate(ctx : DiscountContext) : double
    }

    class PurchaseContext <<record>> {
        + userId : String
        + eventId : String
        + companyId : String
        + quantity : int
        + userAge : int
    }

    class DiscountContext <<record>> {
        + baseTotal : double
        + couponCode : String
        + userId : String
    }

    class DomainException
    class AuthenticationException
    class EntityNotFoundException
    class OptimisticLockException
    class PermissionDeniedException
    class SeatUnavailableException

    DomainException          <|-- AuthenticationException
    DomainException          <|-- EntityNotFoundException
    DomainException          <|-- PermissionDeniedException
    DomainException          <|-- SeatUnavailableException
    RuntimeException         <|-- OptimisticLockException
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — policies (Composite pattern)
'══════════════════════════════════════════════════════════════════

package "domain.policies.purchase" #FFFDE7 {
    class AllowAllPolicy
    class AndPolicy {
        - left  : PurchasePolicy
        - right : PurchasePolicy
    }
    class OrPolicy {
        - left  : PurchasePolicy
        - right : PurchasePolicy
    }
    class MaxTicketsPolicy {
        - maxTickets : int
    }
    class MinTicketsPolicy {
        - minTickets : int
    }
    class AgeRestrictionPolicy {
        - minAge : int
    }

    AllowAllPolicy    ..|> PurchasePolicy
    AndPolicy         ..|> PurchasePolicy
    OrPolicy          ..|> PurchasePolicy
    MaxTicketsPolicy  ..|> PurchasePolicy
    MinTicketsPolicy  ..|> PurchasePolicy
    AgeRestrictionPolicy ..|> PurchasePolicy
}

package "domain.policies.discount" #FFFDE7 {
    class NoDiscountPolicy
    class SimpleDiscount {
        - percentage : double
    }
    class AdditiveDiscountPolicy {
        - policies : List<DiscountPolicy>
    }
    class MaxDiscountPolicy {
        - policies : List<DiscountPolicy>
    }
    class ConditionalDiscount {
        - condition  : PurchasePolicy
        - thenPolicy : DiscountPolicy
    }
    class CouponDiscount {
        - couponCode : String
        - percentage : double
    }

    NoDiscountPolicy      ..|> DiscountPolicy
    SimpleDiscount        ..|> DiscountPolicy
    AdditiveDiscountPolicy ..|> DiscountPolicy
    MaxDiscountPolicy     ..|> DiscountPolicy
    ConditionalDiscount   ..|> DiscountPolicy
    CouponDiscount        ..|> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' DOMAIN — Aggregates.User
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.User" #FFF9C4 {

    enum UserRole {
        GUEST
        MEMBER
        ADMIN
    }

    enum UserState {
        ACTIVE
        INACTIVE
    }

    class User <<AggRoot>> #FFD54F {
        - id            : String
        - username      : String
        - state         : UserState
        - activeOrderId : String
        - suspendedAt   : LocalDateTime
        - suspendedUntil: LocalDateTime
        - version       : int
        + isActive()    : boolean
        + activate()
        + deactivate()
        + suspend(at, until)
        + isSuspended() : boolean
        + getRole()     : UserRole
        + canPurchase() : boolean
        + canManageSystem() : boolean
        + setActiveOrderId(id)
    }

    class Member {
        + setPasswordHash(hash)
        + addCompanyRole(companyId, role, appointedBy)
        + removeCompanyRole(companyId)
        + getCompanyRoles() : Map<String, CompanyRole>
        + getRoleInCompany(companyId) : CompanyRole
    }

    class Guest

    User <|-- Member
    User <|-- Guest
    User --> UserState
    User --> UserRole
}

