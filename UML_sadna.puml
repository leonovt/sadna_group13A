    ProductionCompany  ..> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — Event (show)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Event" #FFF9C4 {
    class Event      <<AggRoot>>
    class VenueMap
    abstract class Zone
    class SeatedZone
    class StandingZone
    class Seat
    enum  EventSaleMode
    enum  SeatStatus
    enum  ZoneType

    Event      *-- VenueMap
    VenueMap   *-- Zone
    Zone       <|-- SeatedZone
    Zone       <|-- StandingZone
    SeatedZone *-- Seat
    Event      --> EventSaleMode
    Zone       --> ZoneType
    Seat       --> SeatStatus
    Event      ..> PurchasePolicy
    Event      ..> DiscountPolicy
}

