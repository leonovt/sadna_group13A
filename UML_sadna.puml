    }
    interface IAdminRepository {
        + findById(id) : Optional<Admin>
        + findByUserId(uid) : Optional<Admin>
        + save(admin)
    }
    interface ICompanyRepository {
        + findById(id) : Optional<ProductionCompany>
        + save(company)
        + findAll() : List<ProductionCompany>
        + deleteById(id)
    }
    interface IEventRepository {
        + findById(id) : Optional<Event>
