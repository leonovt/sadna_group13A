@startuml UML_sadna_group13A
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80
skinparam padding 14
skinparam roundCorner 8

title Sadna Group 13A — Event Ticketing System

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Shared
'══════════════════════════════════════════════════════════════════

package "domain.shared" #FFFDE7 {

    interface PurchasePolicy
    interface DiscountPolicy

    enum    OrderStatus
    class   PurchaseContext <<record>>
    class   DiscountContext <<record>>

    class DomainException
    class AuthenticationException
    class EntityNotFoundException
    class PermissionDeniedException
    class SeatUnavailableException
    class OptimisticLockException

    DomainException <|-- AuthenticationException
    DomainException <|-- EntityNotFoundException
    DomainException <|-- PermissionDeniedException
    DomainException <|-- SeatUnavailableException
    RuntimeException <|-- OptimisticLockException
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Policies  (Composite pattern)
'══════════════════════════════════════════════════════════════════

package "domain.policies.purchase" #FFFDE7 {
    class AllowAllPolicy
    class AndPolicy
    class OrPolicy
    class MaxTicketsPolicy
    class MinTicketsPolicy
    class AgeRestrictionPolicy

    AllowAllPolicy       ..|> PurchasePolicy
    AndPolicy            ..|> PurchasePolicy
    OrPolicy             ..|> PurchasePolicy
    MaxTicketsPolicy     ..|> PurchasePolicy
    MinTicketsPolicy     ..|> PurchasePolicy
    AgeRestrictionPolicy ..|> PurchasePolicy
}

package "domain.policies.discount" #FFFDE7 {
    class NoDiscountPolicy
    class SimpleDiscount
    class AdditiveDiscountPolicy
    class MaxDiscountPolicy
    class ConditionalDiscount
    class CouponDiscount

    NoDiscountPolicy       ..|> DiscountPolicy
    SimpleDiscount         ..|> DiscountPolicy
    AdditiveDiscountPolicy ..|> DiscountPolicy
    MaxDiscountPolicy      ..|> DiscountPolicy
    ConditionalDiscount    ..|> DiscountPolicy
    CouponDiscount         ..|> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — User
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.User" #FFF9C4 {
    class User   <<AggRoot>>
    class Member
    class Guest
    enum  UserRole
    enum  UserState

    User <|-- Member
    User <|-- Guest
    User --> UserState
    User --> UserRole
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — Admin
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Admin" #FFF9C4 {
    class Admin <<AggRoot>>
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — Company
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Company" #FFF9C4 {
    class ProductionCompany   <<AggRoot>>
    class CompanyStaffMember
    class AppointmentRequest
    enum  CompanyRole
    enum  CompanyStatus
    enum  CompanyPermission

    ProductionCompany  *-- CompanyStaffMember
    ProductionCompany  *-- AppointmentRequest
    ProductionCompany  --> CompanyStatus
    CompanyStaffMember --> CompanyRole
    CompanyStaffMember --> CompanyPermission
    AppointmentRequest --> CompanyRole
    ProductionCompany  ..> PurchasePolicy
    ProductionCompany  ..> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — Event (show)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Event" #FFF9C4 {
    class Event      <<AggRoot>>
    class VenueMap
    abstract class Zone
    class SeatedZone
    class StandingZone
    class Seat
    enum  EventSaleMode
    enum  SeatStatus
    enum  ZoneType

    Event      *-- VenueMap
    VenueMap   *-- Zone
    Zone       <|-- SeatedZone
    Zone       <|-- StandingZone
    SeatedZone *-- Seat
    Event      --> EventSaleMode
    Zone       --> ZoneType
    Seat       --> SeatStatus
    Event      ..> PurchasePolicy
    Event      ..> DiscountPolicy
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — ActiveOrder  (shopping cart)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.ActiveOrder" #FFF9C4 {
    class ActiveOrder <<AggRoot>>
    class OrderItem   <<VO>>

    ActiveOrder *-- OrderItem
    ActiveOrder --> OrderStatus
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — OrderHistory  (receipts + checkout session)
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.OrderHistory" #FFF9C4 {
    class OrderHistory    <<AggRoot>>
    class OrderHistoryItem <<VO>>

    class "ActiveOrder\n(Checkout Session)" as CheckoutSession <<AggRoot>>
    class "OrderItem\n(Checkout)"           as CheckoutItem   <<VO>>

    OrderHistory    *-- OrderHistoryItem
    CheckoutSession *-- CheckoutItem
    CheckoutSession --> OrderStatus
    CheckoutSession --> UserRole
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — Raffle
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.Raffle" #FFF9C4 {
    class Raffle            <<AggRoot>>
    class AuthorizationCode
    enum  RaffleStatus

    Raffle *-- AuthorizationCode
    Raffle --> RaffleStatus
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Aggregates — TicketQueue
'══════════════════════════════════════════════════════════════════

package "domain.Aggregates.TicketQueue" #FFF9C4 {
    class TicketQueue <<AggRoot>>
    class QueueTicket

    TicketQueue *-- QueueTicket
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Domain Services
'══════════════════════════════════════════════════════════════════

package "domain.DomainServices" #FFFDE7 {
    class CheckoutDomainService
    class TicketingAccessDomainService
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Repository Interfaces
'══════════════════════════════════════════════════════════════════

package "domain.Interfaces" #FFFDE7 {
    interface IUserRepository
    interface IAdminRepository
    interface ICompanyRepository
    interface IEventRepository
    interface IActiveOrderRepository
    interface IOrderHistoryRepository
    interface IRaffleRepository
    interface IQueueRepository
    interface IOrderQueueRepository
}

'══════════════════════════════════════════════════════════════════
' LAYER 1 — DOMAIN : Domain Events  (Spring ApplicationEvent records)
'══════════════════════════════════════════════════════════════════

package "domain.Events" #FFFDE7 {

    together {
        class UserBannedEvent        <<record>>
        class UserReactivatedEvent   <<record>>
    }

    together {
        class OrderCompletedEvent    <<record>>
        class CartExpiredEvent       <<record>>
        class CheckoutFailedEvent    <<record>>
    }

    together {
        class QueueTurnArrivedEvent  <<record>>
    }

    together {
        class RaffleDrawnEvent       <<record>>
        class RaffleWonEvent         <<record>>
    }

    together {
        class CompanyClosedByAdminEvent <<record>>
        class CompanySuspendedEvent     <<record>>
        class CompanyReopenedEvent      <<record>>
        class StaffNominatedEvent       <<record>>
        class StaffRemovedEvent         <<record>>
        class PermissionsUpdatedEvent   <<record>>
    }

    together {
        class EventCancelledEvent    <<record>>
        class EventRescheduledEvent  <<record>>
        class EventSoldOutEvent      <<record>>
    }

    together {
        class AdminMessageEvent      <<record>>
    }
}

'══════════════════════════════════════════════════════════════════
' LAYER 2 — APPLICATION : Interfaces & Result
'══════════════════════════════════════════════════════════════════

package "application.Interfaces" #E3F2FD {
    interface IAuth
    interface IPasswordEncoder
    interface IPaymentGateway
    interface ITicketSupplier
    interface INotificationService
    class     Result<T>
}

'══════════════════════════════════════════════════════════════════
' LAYER 2 — APPLICATION : DTOs
'══════════════════════════════════════════════════════════════════

package "application.DTO" #E3F2FD {
    class CompanyDTO          <<record>>
    class EventDTO            <<record>>
    class OrderHistoryDTO     <<record>>
    class OrderHistoryItemDTO <<record>>
    class SalesReportDTO      <<record>>
    class UserDTO             <<record>>
    class StaffMemberDTO      <<record>>
    class VenueMapDTO         <<record>>
    class ZoneDTO             <<record>>
    class SeatDTO             <<record>>
    class RaffleDTO           <<record>>
    class RaffleResultDTO     <<record>>
    class WinningTicketDTO    <<record>>
    class QueueStatusDTO      <<record>>
    class SuspensionDTO       <<record>>
    class SystemAnalyticsDTO  <<record>>
}

'══════════════════════════════════════════════════════════════════
' LAYER 2 — APPLICATION : Services
'══════════════════════════════════════════════════════════════════

package "application.Services" #E3F2FD {
    class UserService
    class CompanyService
    class EventService
    class OrderService
    class RaffleService
    class QueueService
    class AdminService
    class CartCleanupService
    class SystemLogService
    class SystemService
}

'══════════════════════════════════════════════════════════════════
' LAYER 2 — APPLICATION : Event Listeners
'══════════════════════════════════════════════════════════════════

package "application.EventListeners" #E3F2FD {
    class NotificationEventListener
    class CompanyEventListener
}

'══════════════════════════════════════════════════════════════════
' LAYER 3 — INFRASTRUCTURE
'══════════════════════════════════════════════════════════════════

package "infrastructure" #ECEFF1 {
    class AuthImpl
    class PasswordEncoderImpl
    class InMemoryNotificationService
    class StubPaymentGateway
    class StubTicketSupplier
    class PlatformBootstrap

    package "infrastructure.RepositoryImpl" #E0E0E0 {
        class UserRepositoryImpl
        class AdminRepositoryImpl
        class CompanyRepositoryImpl
        class EventRepositoryImpl
        class ActiveOrderRepositoryImpl
        class OrderHistoryRepositoryImpl
        class RaffleRepositoryImpl
        class QueueRepositoryImpl
        class OrderQueueRepositoryImpl
    }
}

'══════════════════════════════════════════════════════════════════
' LAYER 4 — PRESENTATION
'══════════════════════════════════════════════════════════════════

package "presentation.notification" #ECEFF1 {
    class WebSocketNotificationService
}

'══════════════════════════════════════════════════════════════════
' INTERFACE IMPLEMENTATIONS
'══════════════════════════════════════════════════════════════════

AuthImpl                     ..|> IAuth
PasswordEncoderImpl          ..|> IPasswordEncoder
InMemoryNotificationService  ..|> INotificationService
WebSocketNotificationService ..|> INotificationService
StubPaymentGateway           ..|> IPaymentGateway
StubTicketSupplier           ..|> ITicketSupplier

UserRepositoryImpl         ..|> IUserRepository
AdminRepositoryImpl        ..|> IAdminRepository
CompanyRepositoryImpl      ..|> ICompanyRepository
EventRepositoryImpl        ..|> IEventRepository
ActiveOrderRepositoryImpl  ..|> IActiveOrderRepository
OrderHistoryRepositoryImpl ..|> IOrderHistoryRepository
RaffleRepositoryImpl       ..|> IRaffleRepository
QueueRepositoryImpl        ..|> IQueueRepository
OrderQueueRepositoryImpl   ..|> IOrderQueueRepository

'══════════════════════════════════════════════════════════════════
' SERVICE → REPOSITORY & GATEWAY DEPENDENCIES
'══════════════════════════════════════════════════════════════════

UserService    ..> IUserRepository
UserService    ..> IPasswordEncoder
UserService    ..> IAuth
UserService    ..> IOrderHistoryRepository

CompanyService ..> ICompanyRepository
CompanyService ..> IUserRepository
CompanyService ..> IOrderHistoryRepository
CompanyService ..> IAuth

EventService   ..> IEventRepository
EventService   ..> ICompanyRepository
EventService   ..> IUserRepository
EventService   ..> IAuth

OrderService   ..> IActiveOrderRepository
OrderService   ..> IOrderHistoryRepository
OrderService   ..> IEventRepository
OrderService   ..> ICompanyRepository
OrderService   ..> IQueueRepository
OrderService   ..> IRaffleRepository
OrderService   ..> IUserRepository
OrderService   ..> IPaymentGateway
OrderService   ..> ITicketSupplier
OrderService   ..> IAuth
OrderService   ..> CheckoutDomainService
OrderService   ..> TicketingAccessDomainService

RaffleService  ..> IRaffleRepository
RaffleService  ..> IEventRepository
RaffleService  ..> ICompanyRepository
RaffleService  ..> IUserRepository
RaffleService  ..> IAuth

QueueService   ..> IQueueRepository
QueueService   ..> IEventRepository
QueueService   ..> ICompanyRepository
QueueService   ..> IUserRepository
QueueService   ..> IAdminRepository
QueueService   ..> IAuth

AdminService   ..> IAdminRepository
AdminService   ..> IUserRepository
AdminService   ..> ICompanyRepository
AdminService   ..> IEventRepository
AdminService   ..> IQueueRepository
AdminService   ..> IOrderHistoryRepository
AdminService   ..> IAuth
AdminService   ..> SystemLogService

CartCleanupService ..> IActiveOrderRepository
CartCleanupService ..> IEventRepository

NotificationEventListener ..> INotificationService
CompanyEventListener      ..> ICompanyRepository

@enduml
