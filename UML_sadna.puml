'══════════════════════════════════════════════════════════════════
' APPLICATION — Interfaces
'══════════════════════════════════════════════════════════════════

package "application.Interfaces" #E3F2FD {

    interface IAuth {
        + generateToken(userId) : String
        + validateToken(token)  : boolean
        + extractUserId(token)  : String
    }

    interface IPasswordEncoder {
        + encode(raw)             : String
        + matches(raw, encoded)   : boolean
    }

    interface IPaymentGateway {
        + processPayment(amount, paymentInfo) : Result<String>
    }

    interface ITicketSupplier {
        + issueTickets(items, quantity) : Result<List<String>>
    }

    interface INotificationService {
        ' ── Core ─────────────────────────────────────
        + notifyOrderCompleted(userId, receiptId, totalPaid)
        + notifyQueueTurnArrived(userId, eventId, expiresAt)
        + notifyUserBanned(userId, adminId)
        + notifyCompanyClosed(staffIds, companyId, adminId)
        + notifyRaffleDrawn(eventId, winnerCount)
        + notifyActionFailed(userId, reason)
        ' ── Company lifecycle ─────────────────────────
        + notifyCompanySuspended(staffIds, companyId)
        + notifyCompanyReopened(staffIds, companyId)
        + notifyStaffNominated(userId, companyId, role)
        + notifyStaffRemoved(userId, companyId)
        + notifyPermissionsUpdated(userId, companyId)
        ' ── Order / event ─────────────────────────────
        + notifyCartExpired(userId)
        + notifyEventCancelled(buyerIds, eventId, title)
        + notifyEventRescheduled(buyerIds, eventId, title, newDate)
        + notifyEventSoldOut(staffIds, eventId, title)
        + notifyRaffleWon(userId, eventId, authCode, expiresAt)
        + notifyUserReactivated(userId)
        + notifyAdminMessage(userId, message)
    }

    class Result<T> {
        - success      : boolean
        - value        : T
        - errorMessage : String
        {static} + success(value) : Result<T>
        {static} + failure(msg)   : Result<T>
        + isSuccess()      : boolean
        + getOrThrow()     : T
        + getErrorMessage(): String
    }
}

